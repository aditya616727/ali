# ──────────────────────────────────────────────────────────────────────────────
# MongoDB
# ──────────────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/

# ──────────────────────────────────────────────────────────────────────────────
# Cloudflare Images  (used to re-host product images)
# ──────────────────────────────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# ──────────────────────────────────────────────────────────────────────────────
# Browser
# ──────────────────────────────────────────────────────────────────────────────
# Set to true for headless mode (required in Docker / CI)
HEADLESS=true
# Leave empty to use the bundled Chromium
CHROME_PATH=
# Set to false only inside Docker (no-sandbox mode)
CHROME_SANDBOX=true

# ──────────────────────────────────────────────────────────────────────────────
# Scraping behaviour
# ──────────────────────────────────────────────────────────────────────────────
# Number of listing pages to scrape; -1 = scrape all pages
MAX_PAGES=5
# Random delay between listing pages (seconds)
DELAY_MIN=2
DELAY_MAX=5
MAX_CONCURRENT_TABS=1
MAX_CONCURRENT_UPLOADS=5

# ──────────────────────────────────────────────────────────────────────────────
# Output
# ──────────────────────────────────────────────────────────────────────────────
OUTPUT_DIR=output

# ──────────────────────────────────────────────────────────────────────────────
# Proxy  (Webshare backbone proxies)
# ──────────────────────────────────────────────────────────────────────────────
USE_PROXY=true
WEBSHARE_API_KEY=your_webshare_api_key
# Comma-separated ISO country codes to filter proxies; leave empty for all countries
PROXY_COUNTRIES=SG,JP,DE,FR,CH,TW,KR,PL,BE,CA,IT,DK,IN,RO,GE

# ──────────────────────────────────────────────────────────────────────────────
# CAPTCHA solving  (CapSolver — https://capsolver.com)
# ──────────────────────────────────────────────────────────────────────────────
CAPSOLVER_API_KEY=CAP-your_capsolver_api_key

# ──────────────────────────────────────────────────────────────────────────────
# Detail page scraping
# ──────────────────────────────────────────────────────────────────────────────
# Visit each product's detail page to get full specs, images, and price tiers
SCRAPE_DETAILS=true
# How many times to retry a CAPTCHA on a detail page before giving up
MAX_CAPTCHA_RETRIES=2
# Parallel workers for detail pages (each uses a different proxy)
DETAIL_WORKERS=3
# Max number of products to scrape details for; -1 = all
DETAIL_LIMIT=-1
# Re-scrape products that already exist in MongoDB
FORCE_RESCRAPE=false
# Save a minimal document even when detail scraping fails
STORE_FAILED_PRODUCTS=false
